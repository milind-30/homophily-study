@article{tajfel1979integrative,
  title={An integrative theory of intergroup conflict},
  author={Tajfel, Henri and Turner, John C and Austin, William G and Worchel, Stephen},
  journal={Organizational identity: A reader},
  volume={56},
  number={65},
  pages={9780203505984--16},
  year={1979},
  publisher={Oxford University Press},
  note = {Social Identity Theory (Tajfel & Turner, 1979) holds that we categorize ourselves and others into social groups, favoring those we perceive as ingroup members. Demographic similarity (e.g. shared gender, ethnicity) often signals ingroup status, eliciting ingroup favoritism -- an automatic tendency to prefer “people who are like us” under the additional assumption that similarity corresponds to ingroup membership. Reviewed experiments construct "minimal groups" from random or arbitrary assortment and find that this is sufficient to establish favoritism.Suggests an intrinsic preference for self-similar others that may be contrasted with an instrumental account of homophily, where self-similarity is a signal of prospective relational benefits. I could use this to set up the contrast or in a review of the literature on homophily.} 
}
